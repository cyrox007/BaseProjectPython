# Режим отладки (по умолчанию: False)
DEBUG=True

# Настройки сервера (опционально)
SERVER_HTTP_PROTOCOL=http://   # или https://
SERVER_ADDR=localhost           # или ваш IP/домен
SERVER_PORT=9000

# CORS разрешенные источники (через запятую)
ALLOWED_ORIGINS=http://localhost:3000,https://example.com

# PostgreSQL (по умолчанию: localhost, 5432, wb, postgres, postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=wb
DB_USER=postgres
DB_PASSWORD=your_strong_password_here

# Ключ шифрования для API токенов (обязательный!)
API_TOKEN_ENCRYPTION_KEY=your-encryption-key-here

# JWT секретный ключ (обязательный в production)
JWT_SECRET_KEY=your-super-secret-jwt-key-change-me

# Redis URL (по умолчанию: redis://localhost:6379/0)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300
CACHE_ENABLED=true